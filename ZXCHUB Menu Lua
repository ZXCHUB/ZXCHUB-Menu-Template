-- INPUT BOX
-- flag     — key in Flags (stores string)
-- callback — function(string)
-- Returns: nextY, boxInstance
-- ════════════════════════════════════════════════════════
local function MakeInput(parent, text, placeholder, yOff, flag, callback)
    local cont=Frame(parent,UDim2.new(1,-32,0,48),UDim2.new(0,16,0,yOff),C.bg0)
    cont.BackgroundTransparency=1
    Lbl(cont,text,isMobile and 12 or 11,C.txt,Enum.Font.Gotham).Size=UDim2.new(1,0,0,isMobile and 19 or 17)

    local box=Instance.new("TextBox",cont)
    local bH=isMobile and 26 or 23
    box.Size=UDim2.new(1,0,0,bH); box.Position=UDim2.new(0,0,0,isMobile and 20 or 18)
    box.BackgroundColor3=C.bg3; box.BorderSizePixel=0
    box.Font=Enum.Font.GothamMedium; box.TextSize=isMobile and 11 or 11
    box.TextColor3=C.txt; box.PlaceholderColor3=C.txt3
    box.PlaceholderText=placeholder; box.Text=Flags[flag] or ""
    box.TextXAlignment=Enum.TextXAlignment.Left; box.ClearTextOnFocus=false
    Instance.new("UICorner",box).CornerRadius=UDim.new(0,4)
    Instance.new("UIPadding",box).PaddingLeft=UDim.new(0,7)
    local st=Stroke(box,C.brd2,1)
    Setters[flag]=function(v) Flags[flag]=v; box.Text=v end
    box:GetPropertyChangedSignal("Text"):Connect(function()
        Flags[flag]=box.Text; if callback then callback(box.Text) end end)
    box.Focused:Connect(function() st.Color=C.acc end)
    box.FocusLost:Connect(function() st.Color=C.brd2 end)
    return yOff+(isMobile and 54 or 48), box
end

-- ════════════════════════════════════════════════════════
-- SELECT  (popup with single-choice radio buttons)
-- options  — array of strings
-- callback — function(selectedString)
-- ════════════════════════════════════════════════════════
local function MakeSelect(parent, text, yOff, options, callback)
    local bH=isMobile and 30 or 26
    local b=Btn(parent,UDim2.new(1,-32,0,bH),UDim2.new(0,16,0,yOff),C.bg3,4)
    Stroke(b,C.brd2,1)

    local currentVal = options[1] or ""

    -- Button shows current value
    local bLbl=Lbl(b,text.."  :  "..currentVal,isMobile and 11 or 11,C.txt,Enum.Font.GothamMedium,Enum.TextXAlignment.Left)
    bLbl.Size=UDim2.new(1,-28,1,0); bLbl.Position=UDim2.new(0,10,0,0)
    local arrow=Lbl(b,"v",isMobile and 10 or 9,C.txt2,Enum.Font.GothamBold,Enum.TextXAlignment.Right)
    arrow.Size=UDim2.new(0,20,1,0); arrow.Position=UDim2.new(1,-22,0,0)

    b.MouseButton1Click:Connect(function()
        -- Small popup directly over the button
        local popW  = isMobile and math.min(260, workspace.CurrentCamera.ViewportSize.X-20) or 240
        local itemH = isMobile and 36 or 30
        local popH  = math.min(#options*itemH+16, isMobile and 300 or 260)

        local pop=Frame(GUI,UDim2.new(0,popW,0,popH),UDim2.new(0,0,0,0),C.bg0,6)
        Stroke(pop,C.brd2,1); pop.ZIndex=110; pop.ClipsDescendants=true

        -- Position below the button
        local absPos=b.AbsolutePosition
        local absSize=b.AbsoluteSize
        local vp=workspace.CurrentCamera.ViewportSize
        local px=math.clamp(absPos.X, 4, vp.X-popW-4)
        local py=absPos.Y+absSize.Y+4
        if py+popH > vp.Y-4 then py=absPos.Y-popH-4 end
        pop.Position=UDim2.new(0,px,0,py)

        -- Scrollable list
        local sc2=MakeScroll(pop)
        sc2.Size=UDim2.new(1,-4,1,-4); sc2.Position=UDim2.new(0,2,0,2)

        for i,opt in ipairs(options) do
            local isSelected = opt==currentVal
            local ib=Btn(sc2,UDim2.new(1,0,0,itemH),UDim2.new(0,0,0,(i-1)*itemH),
                isSelected and C.bg4 or C.bg3)
            Stroke(ib,C.brd,1)

            -- Radio dot
            local dotSz=isMobile and 10 or 8
            local dotF=Frame(ib,UDim2.new(0,dotSz,0,dotSz),UDim2.new(0,isMobile and 12 or 10,0.5,-dotSz/2),
                isSelected and C.acc or C.bg4, dotSz/2)
            Stroke(dotF,C.brd2,1)

            local iL=Lbl(ib,opt,isMobile and 12 or 11,isSelected and C.white or C.txt,Enum.Font.GothamMedium)
            iL.Size=UDim2.new(1,-(dotSz+24),1,0); iL.Position=UDim2.new(0,dotSz+18,0,0)

            ib.MouseButton1Click:Connect(function()
                currentVal=opt
                bLbl.Text=text.."  :  "..currentVal
                if callback then callback(opt) end
                pop:Destroy()
            end)
        end

        -- Click outside to close
        local overlay=Btn(GUI,UDim2.new(1,0,1,0),UDim2.new(0,0,0,0),C.bg0)
        overlay.BackgroundTransparency=1; overlay.ZIndex=109
        overlay.MouseButton1Click:Connect(function()
            pop:Destroy(); overlay:Destroy()
        end)
    end)

    return yOff+(isMobile and 38 or 34)
end

-- ════════════════════════════════════════════════════════
-- MULTI SELECT  (popup with checkboxes, pick multiple)
-- options  — array of strings
-- callback — function(selectedTable)
-- ════════════════════════════════════════════════════════
local function MakeMultiSelect(parent, text, yOff, options, callback)
    local bH=isMobile and 30 or 26
    local b=Btn(parent,UDim2.new(1,-32,0,bH),UDim2.new(0,16,0,yOff),C.bg3,4)
    Stroke(b,C.brd2,1)

    local selected={}
    local function GetSelectedStr()
        if #selected==0 then return "None" end
        if #selected>2 then return selected[1]..", +"..tostring(#selected-1) end
        return table.concat(selected,", ")
    end

    local bLbl=Lbl(b,text.."  :  None",isMobile and 11 or 11,C.txt,Enum.Font.GothamMedium,Enum.TextXAlignment.Left)
    bLbl.Size=UDim2.new(1,-28,1,0); bLbl.Position=UDim2.new(0,10,0,0)
    local arrow2=Lbl(b,"v",isMobile and 10 or 9,C.txt2,Enum.Font.GothamBold,Enum.TextXAlignment.Right)
    arrow2.Size=UDim2.new(0,20,1,0); arrow2.Position=UDim2.new(1,-22,0,0)

    b.MouseButton1Click:Connect(function()
        local popW  = isMobile and math.min(260,workspace.CurrentCamera.ViewportSize.X-20) or 240
        local itemH = isMobile and 38 or 32
        -- Header + items + confirm button
        local headH = isMobile and 36 or 30
        local btnH  = isMobile and 38 or 32
        local popH  = math.min(headH+#options*itemH+btnH+12, isMobile and 340 or 300)

        local pop=Frame(GUI,UDim2.new(0,popW,0,popH),UDim2.new(0,0,0,0),C.bg0,6)
        Stroke(pop,C.brd2,1); pop.ZIndex=110; pop.ClipsDescendants=true

        local absPos=b.AbsolutePosition; local absSize=b.AbsoluteSize
        local vp=workspace.CurrentCamera.ViewportSize
        local px=math.clamp(absPos.X,4,vp.X-popW-4)
        local py=absPos.Y+absSize.Y+4
        if py+popH>vp.Y-4 then py=absPos.Y-popH-4 end
        pop.Position=UDim2.new(0,px,0,py)

        -- Header
        local head=Frame(pop,UDim2.new(1,0,0,headH),UDim2.new(0,0,0,0),C.bg1)
        Frame(head,UDim2.new(1,0,0,2),UDim2.new(0,0,1,-2),C.acc)
        Lbl(head,text,isMobile and 11 or 11,C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

        -- Scrollable items
        local sc3=MakeScroll(pop)
        sc3.Size=UDim2.new(1,-4,1,-(headH+btnH+10)); sc3.Position=UDim2.new(0,2,0,headH+4)

        local states={}
        for i,opt in ipairs(options) do
            states[opt]=table.find(selected,opt)~=nil
        end
        local itemBtns={}

        for i,opt in ipairs(options) do
            local ib=Btn(sc3,UDim2.new(1,0,0,itemH),UDim2.new(0,0,0,(i-1)*itemH),
                states[opt] and C.bg4 or C.bg3)
            Stroke(ib,C.brd,1)

            -- Checkbox
            local cbSz=isMobile and 14 or 12
            local cbF=Frame(ib,UDim2.new(0,cbSz,0,cbSz),UDim2.new(0,isMobile and 10 or 8,0.5,-cbSz/2),
                states[opt] and C.acc or C.bg4, 3)
            Stroke(cbF,C.brd2,1)
            local cbTick=Lbl(cbF,states[opt] and "v" or "",isMobile and 9 or 8,
                C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

            local iL=Lbl(ib,opt,isMobile and 12 or 11,states[opt] and C.white or C.txt,Enum.Font.GothamMedium)
            iL.Size=UDim2.new(1,-(cbSz+20),1,0); iL.Position=UDim2.new(0,cbSz+14,0,0)

            itemBtns[opt]={frame=ib,cb=cbF,tick=cbTick,lbl=iL}

            ib.MouseButton1Click:Connect(function()
                states[opt]=not states[opt]
                TweenS:Create(cbF,TweenInfo.new(0.1),{BackgroundColor3=states[opt] and C.acc or C.bg4}):Play()
                cbTick.Text = states[opt] and "v" or ""
                iL.TextColor3 = states[opt] and C.white or C.txt
                TweenS:Create(ib,TweenInfo.new(0.1),{BackgroundColor3=states[opt] and C.bg4 or C.bg3}):Play()
            end)
        end

        -- Confirm button
        local confBtn=Btn(pop,UDim2.new(1,-8,0,btnH-6),UDim2.new(0,4,1,-(btnH)),C.acc,4)
        Lbl(confBtn,"Confirm",isMobile and 12 or 11,C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)

        confBtn.MouseButton1Click:Connect(function()
            selected={}
            for _,opt in ipairs(options) do
                if states[opt] then table.insert(selected,opt) end
            end
            bLbl.Text=text.."  :  "..GetSelectedStr()
            if callback then callback(selected) end
            pop:Destroy()
        end)
    end)

    return yOff+(isMobile and 38 or 34)
end

-- ════════════════════════════════════════════════════════
-- COLOR PICKER  (popup with R/G/B sliders + live preview)
-- Toast fires only when closing the popup
-- flag     — key in Flags (stores {r,g,b} 0-255)
-- callback — function(r,g,b)
-- ════════════════════════════════════════════════════════
local function MakeColorPicker(parent, text, yOff, flag, callback)
    Flags[flag]=Flags[flag] or {r=215,g=55,b=55}

    local rH=isMobile and 30 or 26
    local row=Frame(parent,UDim2.new(1,-32,0,rH),UDim2.new(0,16,0,yOff),C.bg0)
    row.BackgroundTransparency=1

    local nL=Lbl(row,text,isMobile and 12 or 11,C.txt,Enum.Font.Gotham)
    nL.Size=UDim2.new(1,-54,1,0)

    -- Color preview swatch
    local swSz=isMobile and 22 or 18
    local swatch=Frame(row,UDim2.new(0,swSz,0,swSz),UDim2.new(1,-swSz-2,0.5,-swSz/2),
        Color3.fromRGB(Flags[flag].r,Flags[flag].g,Flags[flag].b),4)
    Stroke(swatch,C.brd2,1)

    -- "Edit" label
    local editLbl=Lbl(row,"Edit",isMobile and 10 or 9,C.txt2,Enum.Font.GothamMedium,Enum.TextXAlignment.Right)
    editLbl.Size=UDim2.new(0,28,1,0); editLbl.Position=UDim2.new(1,-swSz-34,0,0)

    local function UpdateSwatch()
        swatch.BackgroundColor3=Color3.fromRGB(Flags[flag].r,Flags[flag].g,Flags[flag].b)
    end

