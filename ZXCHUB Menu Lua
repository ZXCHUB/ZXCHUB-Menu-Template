            local function SCV(v)
                local iv=math.clamp(math.floor(v+0.5),0,255)
                Flags[flag][colorKey]=iv
                local pct=iv/255
                fill2.Size=UDim2.new(pct,0,1,0)
                thumb2.Position=UDim2.new(pct,-t2Sz/2,0.5,-t2Sz/2)
                vLbl2.Text=tostring(iv)
                RefreshAll()  -- live update preview
            end
            local function P2V2(ax)
                return 0+255*math.clamp((ax-track2.AbsolutePosition.X)/track2.AbsoluteSize.X,0,1)
            end
            SCV(Flags[flag][colorKey])

            track2.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    drag2=true; SCV(P2V2(i.Position.X)) end end)
            thumb2.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
