-- Load character into viewport
local function TryLoadChar()
    -- clear previous
    for _,ch in ipairs(VP:GetChildren()) do
        if not ch:IsA("Camera") then ch:Destroy() end
    end
    local char=lp.Character
    if not char then return end

    local clone=char:Clone()
    -- remove scripts so they don't run
    for _,s in ipairs(clone:GetDescendants()) do
        if s:IsA("BaseScript") then s:Destroy() end
    end
    clone.Parent=VP

    local cam=Instance.new("Camera",VP)
    VP.CurrentCamera=cam

    -- find a good anchor point
    local anchor = clone:FindFirstChild("Head")
                or clone:FindFirstChild("UpperTorso")
                or clone:FindFirstChild("HumanoidRootPart")
                or clone:FindFirstChild("Torso")

    if anchor then
        -- position camera in front of character's head
        cam.CFrame=CFrame.new(anchor.Position+Vector3.new(0,0.5,3.5), anchor.Position+Vector3.new(0,0.5,0))
    end

    -- hide accessories / hats that might block
    for _,p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") then p.CastShadow=false end
    end
end

