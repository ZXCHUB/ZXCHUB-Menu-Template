CheckFn("isfile",     isfile,     "Check if a file exists",                      "Filesystem")
CheckFn("listfiles",  listfiles,  "List saved config files",                     "Filesystem")
CheckFn("delfile",    delfile,    "Delete config files",                          "Filesystem")
