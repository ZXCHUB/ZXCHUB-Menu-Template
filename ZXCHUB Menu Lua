-- EXECUTOR FUNCTION CHECKS
-- Each entry describes what the function does so the user
-- knows exactly what's supported and what isn't
-- ════════════════════════════════════════════════════════
local UnsupportedFunctions = {}
local AllFunctions = {}

local function CheckFn(name, fn, desc, cat)
    local supported = fn ~= nil
    table.insert(AllFunctions, {name=name, desc=desc, cat=cat or "Other", supported=supported})
    if not supported then
        table.insert(UnsupportedFunctions, {name=name, desc=desc, cat=cat or "Other"})
    end
end

CheckFn("readfile",   readfile,   "Read saved config files from disk",           "Filesystem")
CheckFn("writefile",  writefile,  "Write config files to disk",                  "Filesystem")
CheckFn("makefolder", makefolder, "Create folders for configs",                  "Filesystem")
